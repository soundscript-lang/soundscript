{
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.18",
    "@std/path": "jsr:@std/path@1.1.4",
    "@soundscript/macros": "./src/macros.ts",
    "@soundscript/soundscript": "./src/stdlib/index.ts",
    "@soundscript/soundscript/hkt": "./src/stdlib/hkt.ts",
    "@soundscript/soundscript/typeclasses": "./src/stdlib/typeclasses.ts",
    "@soundscript/soundscript/result": "./src/stdlib/result.ts",
    "@soundscript/soundscript/match": "./src/stdlib/match.ts",
    "@soundscript/soundscript/failures": "./src/stdlib/failures.ts",
    "@soundscript/soundscript/url": "./src/stdlib/url.ts",
    "@soundscript/soundscript/fetch": "./src/stdlib/fetch.ts",
    "@soundscript/soundscript/text": "./src/stdlib/text.ts",
    "@soundscript/soundscript/random": "./src/stdlib/random.ts",
    "@soundscript/soundscript/json": "./src/stdlib/json.ts",
    "@soundscript/soundscript/compare": "./src/stdlib/compare.ts",
    "@soundscript/soundscript/hash": "./src/stdlib/hash.ts",
    "@soundscript/soundscript/decode": "./src/stdlib/decode.ts",
    "@soundscript/soundscript/encode": "./src/stdlib/encode.ts",
    "@soundscript/soundscript/codec": "./src/stdlib/codec.ts",
    "@soundscript/soundscript/async": "./src/stdlib/async.ts",
    "@soundscript/soundscript/thunk": "./src/stdlib/thunk.ts",
    "@soundscript/soundscript/experimental/sql": "./src/stdlib/sql.ts",
    "@soundscript/soundscript/experimental/css": "./src/stdlib/css.ts",
    "@soundscript/soundscript/experimental/graphql": "./src/stdlib/graphql.ts",
    "@soundscript/soundscript/experimental/debug": "./src/stdlib/debug.ts",
    "sts:prelude": "./src/stdlib/index.ts",
    "sts:hkt": "./src/stdlib/hkt.ts",
    "sts:typeclasses": "./src/stdlib/typeclasses.ts",
    "sts:result": "./src/stdlib/result.ts",
    "sts:value": "./src/stdlib/value.ts",
    "sts:match": "./src/stdlib/match.ts",
    "sts:failures": "./src/stdlib/failures.ts",
    "sts:url": "./src/stdlib/url.ts",
    "sts:fetch": "./src/stdlib/fetch.ts",
    "sts:text": "./src/stdlib/text.ts",
    "sts:random": "./src/stdlib/random.ts",
    "sts:json": "./src/stdlib/json.ts",
    "sts:compare": "./src/stdlib/compare.ts",
    "sts:hash": "./src/stdlib/hash.ts",
    "sts:decode": "./src/stdlib/decode.ts",
    "sts:encode": "./src/stdlib/encode.ts",
    "sts:codec": "./src/stdlib/codec.ts",
    "sts:async": "./src/stdlib/async.ts",
    "sts:thunk": "./src/stdlib/thunk.ts",
    "sts:experimental/sql": "./src/stdlib/sql.ts",
    "sts:experimental/css": "./src/stdlib/css.ts",
    "sts:experimental/graphql": "./src/stdlib/graphql.ts",
    "sts:experimental/debug": "./src/stdlib/debug.ts",
    "typescript": "npm:typescript@5.9.3",
    "wabt": "npm:wabt@^1.0.39"
  },
  "exclude": [
    ".worktrees/",
    "src/bundled/sound-libs/",
    "src/bundled/typescript/",
    "tests/test262/cases/raw/"
  ],
  "nodeModulesDir": "auto",
  "tasks": {
    "build": "deno compile --allow-env --allow-read --allow-run --allow-write --output ./bin/soundscript src/main.ts && deno run -A scripts/release/stage_cli_runtime_support.ts ./bin",
    "dev": "deno run src/main.ts",
    "check": "deno check src/main.ts src/cli/cli.ts src/lsp_main.ts src/stdlib/*.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "lsp": "deno run --allow-env --allow-read src/lsp_main.ts",
    "smoke:cli": "deno run -A scripts/release/cli_smoke.ts ./bin/soundscript",
    "test:layout": "deno test --allow-read tests/repo/layout_test.ts",
    "test:repo": "deno test --allow-read tests/repo",
    "test": "deno test --allow-env --allow-read --allow-write --allow-run",
    "verify": "deno fmt --check && deno lint && deno task check && deno task test:layout && deno task test"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
