    "sts:env": "./src/stdlib/env.ts",
    "sts:cli": "./src/stdlib/cli.ts",
    "sts:process": "./src/stdlib/process.ts",
    "sts:http": "./src/stdlib/http.ts",
    "sts:net": "./src/stdlib/net.ts",
    "sts:net/dns": "./src/stdlib/net/dns.ts",
    "sts:net/tcp": "./src/stdlib/net/tcp.ts",
    "sts:net/tls": "./src/stdlib/net/tls.ts",
    "sts:thunk": "./src/stdlib/thunk.ts",
    "sts:experimental/sql": "./src/stdlib/sql.ts",
    "sts:experimental/css": "./src/stdlib/css.ts",
    "sts:experimental/graphql": "./src/stdlib/graphql.ts",
    "sts:experimental/debug": "./src/stdlib/debug.ts",
    "typescript": "npm:typescript@5.9.3",
    "wabt": "npm:wabt@^1.0.39"
  },
  "exclude": [
    ".worktrees/",
    "src/bundled/sound-libs/"
  ],
  "nodeModulesDir": "auto",
  "tasks": {
    "build": "deno compile --allow-env --allow-read --allow-run --allow-write --output ./bin/soundscript src/main.ts && deno run -A scripts/release/stage_cli_runtime_support.ts ./bin",
    "dev": "deno run src/main.ts",
    "check": "deno check src/main.ts src/cli/cli.ts src/lsp_main.ts src/stdlib/*.ts src/stdlib/concurrency/*.ts src/stdlib/net/*.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "lsp": "deno run --allow-env --allow-read src/lsp_main.ts",
    "smoke:cli": "deno run -A scripts/release/cli_smoke.ts ./bin/soundscript",
    "test": "deno test --allow-env --allow-read --allow-write --allow-run --allow-net --allow-sys",
    "test:layout": "deno test --allow-read tests/repo/layout_test.ts",
    "verify": "deno fmt --check && deno lint && deno task check && deno task test"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
