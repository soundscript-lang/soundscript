{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run soundscript extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode"
      ],
      "outFiles": [
        "${workspaceFolder}/editors/vscode/out/**/*.js"
      ],
      "preLaunchTask": "compile soundscript extension",
      "env": {
        "SOUNDSCRIPT_LSP_TIMING": "1"
      }
    }
  ]
}
