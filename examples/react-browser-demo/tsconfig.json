{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": [
    "src/**/*.sts",
    "src/**/*.d.ts"
  ],
  "soundscript": {
    "target": "wasm-browser"
  }
}
